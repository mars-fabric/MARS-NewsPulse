# CMBAGENT Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
# For local development: http://localhost:8000
# For remote access: http://<server-ip>:8000 (replace with actual server IP)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL
# For local development: ws://localhost:8000
# For remote access: ws://<server-ip>:8000 (replace with actual server IP)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Work directory for task outputs and logs
# Should match CMBAGENT_DEFAULT_WORK_DIR in backend .env
# Default: ~/Desktop/cmbdir
NEXT_PUBLIC_CMBAGENT_WORK_DIR=~/Desktop/cmbdir

# Optional: Enable debug mode
NEXT_PUBLIC_DEBUG=false

# Framing policy (controls iframe embedding)
# X_FRAME_OPTIONS: SAMEORIGIN (default) | DENY | "" to omit the header
# FRAME_ANCESTORS: CSP frame-ancestors value; defaults to 'self' / 'none' based
# on X_FRAME_OPTIONS. Set explicitly to allow a specific parent, e.g.:
#   FRAME_ANCESTORS='self' https://mars.example.com
# X_FRAME_OPTIONS=SAMEORIGIN
# FRAME_ANCESTORS=
